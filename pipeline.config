#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════════════════════
# pipeline.config — Centralized configuration for the Ebola RNA-seq pipeline
# ═══════════════════════════════════════════════════════════════════════════════
# All tunable parameters live here. No hardcoded values in pipeline scripts.
# Source this file at the top of every script:
#   source "$(dirname "$0")/../pipeline.config"
# ═══════════════════════════════════════════════════════════════════════════════

# ── Project ───────────────────────────────────────────────────────────────────
PROJECT_DIR="/users/PWSU0516/mufakiransari/ebola_class_project"
ACCESSION_LIST="${PROJECT_DIR}/srrAccession.txt"
ACCOUNT="PWSU0516"
NUM_SAMPLES=356
MAX_CONCURRENT=10                 # SLURM array throttle (%N)

# ── Reference Genome (Ebola-only) ────────────────────────────────────────────
REFERENCE_ID="KJ660346.2"        # Ebola virus Makona, 2014 outbreak
REFERENCE_DIR="${PROJECT_DIR}/reference"
REFERENCE_FASTA="${REFERENCE_DIR}/${REFERENCE_ID}.fasta"
REFERENCE_GFF="${REFERENCE_DIR}/${REFERENCE_ID}.gff"
REFERENCE_GTF="${REFERENCE_DIR}/${REFERENCE_ID}.gtf"
HISAT2_INDEX_PREFIX="${REFERENCE_DIR}/hisat2_index/ebola"

# ── Reference Genome (Macaque + Ebola Hybrid) ────────────────────────────────
# Rhesus macaque Mmul_10 (GCF_003339765.3) concatenated with Ebola KJ660346.2
# This enables host + pathogen dual transcriptome analysis
HYBRID_GENOME_DIR="${REFERENCE_DIR}/hybrid"
MACAQUE_FASTA_URL="https://ftp.ncbi.nlm.nih.gov/genomes/all/GCF/003/339/765/GCF_003339765.3_Mmul_10/GCF_003339765.3_Mmul_10_genomic.fna.gz"
MACAQUE_GTF_URL="https://ftp.ncbi.nlm.nih.gov/genomes/all/GCF/003/339/765/GCF_003339765.3_Mmul_10/GCF_003339765.3_Mmul_10_genomic.gtf.gz"
HYBRID_FASTA="${HYBRID_GENOME_DIR}/hybrid_macaque_ebola.fasta"
HYBRID_GTF="${HYBRID_GENOME_DIR}/hybrid_macaque_ebola.gtf"
HISAT2_HYBRID_INDEX_PREFIX="${HYBRID_GENOME_DIR}/hisat2_index/hybrid"
KALLISTO_HYBRID_INDEX="${HYBRID_GENOME_DIR}/hybrid_transcriptome.idx"
HYBRID_TRANSCRIPTOME_FASTA="${HYBRID_GENOME_DIR}/hybrid_transcriptome.fasta"

# ── Output Directories (Ebola-only pipeline) ────────────────────────────────
SRA_DIR="${PROJECT_DIR}/sra_files"
FASTQ_DIR="${PROJECT_DIR}/fastq_outputs"
QC_RAW_DIR="${PROJECT_DIR}/qc_reports/raw"
TRIMMED_DIR="${PROJECT_DIR}/trimmed"
QC_TRIMMED_DIR="${PROJECT_DIR}/qc_reports/trimmed"
ALIGNED_DIR="${PROJECT_DIR}/aligned"
QC_ALIGN_DIR="${PROJECT_DIR}/qc_reports/alignment"
COUNTS_DIR="${PROJECT_DIR}/counts"
VARIANTS_DIR="${PROJECT_DIR}/variants"
DESEQ2_DIR="${PROJECT_DIR}/deseq2_results"
MULTIQC_DIR="${PROJECT_DIR}/multiqc_report"
LOG_DIR="${PROJECT_DIR}/logs"
CHECKPOINT_DIR="${PROJECT_DIR}/.checkpoints"

# ── Output Directories (Hybrid pipeline) ─────────────────────────────────────
HYBRID_ALIGNED_DIR="${PROJECT_DIR}/hybrid_aligned"
HYBRID_COUNTS_DIR="${PROJECT_DIR}/hybrid_counts"
HYBRID_KALLISTO_DIR="${PROJECT_DIR}/hybrid_kallisto_output"

# ── Resource Defaults ────────────────────────────────────────────────────────
THREADS=10
MEMORY="48G"

# ── Trimmomatic Parameters ───────────────────────────────────────────────────
TRIMMOMATIC_ADAPTER_FILE="/apps/spack/0.21/ascend/linux-rhel9-zen2/trimmomatic/gcc/11.4.1/0.38-hmbcfvv/share/adapters/TruSeq3-PE-2.fa"
TRIM_ILLUMINACLIP="${TRIMMOMATIC_ADAPTER_FILE}:2:30:10:2:True"
TRIM_LEADING=3
TRIM_TRAILING=3
TRIM_SLIDINGWINDOW="4:20"
TRIM_MINLEN=36

# ── HISAT2 Parameters ───────────────────────────────────────────────────────
HISAT2_PARAMS="--dta --no-mixed --no-discordant"

# ── Variant Calling Parameters ───────────────────────────────────────────────
BCFTOOLS_MPILEUP_PARAMS="--max-depth 10000 --min-MQ 20 --min-BQ 20"
BCFTOOLS_CALL_PARAMS="--multiallelic-caller --variants-only"
VCF_FILTER_QUAL=20
VCF_FILTER_DP=10

# ── featureCounts Parameters ────────────────────────────────────────────────
# NOTE: Ebola GTF from gffread has transcript/exon/CDS but no 'gene' features.
# We count at the exon level grouped by gene_name (NP, VP35, VP40, GP, VP30, VP24, L)
FC_FEATURE_TYPE="exon"
FC_ATTRIBUTE="gene_name"
FC_EXTRA_PARAMS="-p --countReadPairs -M --fraction -B -C"

# ── Conda Environment ───────────────────────────────────────────────────────
CONDA_ENV="ebola_rnaseq"

# ── HPC Modules ──────────────────────────────────────────────────────────────
MOD_SRA="sratoolkit/3.0.2"
MOD_FASTQC="fastqc/0.12.1"
MOD_TRIMMOMATIC="trimmomatic/0.38"
MOD_HISAT2="hisat2/2.2.1"
MOD_SAMTOOLS="samtools/1.21"
MOD_PICARD="picard/3.0.0"
MOD_BCFTOOLS="bcftools/1.21"
MOD_HTSLIB="htslib/1.20"
MOD_SNPEFF="snpeff/5.2c"
MOD_GCC="gcc/12.3.0"
MOD_R="R/4.4.0"
MOD_CONDA="miniconda3/24.1.2-py310"
